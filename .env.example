# Core
AUTO_TUNE_PERFORMANCE=true
AUTO_TUNE_GOAL=balanced
AUTO_UPDATE_CHECK=true
AUTO_UPDATE_INSTALL=true
AUTO_UPDATE_CACHE_SECONDS=21600
HF_HUB_DISABLE_SYMLINKS_WARNING=1
# owner/repo slug (a full https:// or git@ URL is also accepted and normalized)
NOVA_GITHUB_REPO=cachenetworks/NovaAI
NOVA_GITHUB_BRANCH=main

# LLM
# Providers: ollama | openai | claude-code | codex | cli
#   claude-code / codex shell out to the already-logged-in Claude Code / Codex
#   CLI (no API key, no re-auth — reuses ~/.claude and ~/.codex). Fast cloud
#   responses, great when local Ollama is slow. Requires the CLI installed and
#   logged in once (run `claude` or `codex` in a terminal). Works on
#   Windows/Mac/Linux.
LLM_PROVIDER=cli
LLM_MODEL=dolphin3
LLM_API_URL=
LLM_API_KEY=
LLM_KEEP_ALIVE=30m
LLM_NUM_PREDICT=1200
LLM_TEMPERATURE=0.95

# CLI providers (used when LLM_PROVIDER is claude-code / codex / cli)
# Optional model for the CLI (e.g. sonnet, opus, haiku for Claude; a model id
# for Codex). Leave blank to use the CLI's default.
LLM_CLI_MODEL=
# Override the executable path if `claude` / `codex` aren't on PATH.
CLAUDE_CLI_PATH=
CODEX_CLI_PATH=
# Full custom command for LLM_PROVIDER=cli. Use {prompt} to inject the prompt as
# an argument; omit it to receive the prompt on stdin. Examples:
#   LLM_CLI_COMMAND=claude -p --output-format text
#   LLM_CLI_COMMAND=codex exec --skip-git-repo-check
# Tip: prefer LLM_PROVIDER=codex / claude-code (handles the right flags for you).
LLM_CLI_COMMAND=

# OpenAI Compatible
OPENAI_MODEL=
OPENAI_API_URL=
OPENAI_API_KEY=
OPENAI_TEMPERATURE=

# Ollama
OLLAMA_MODEL=dolphin3
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
OLLAMA_SKIP_LOCAL_SETUP=false
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=1200
OLLAMA_TEMPERATURE=0.95

# Web Search
WEB_BROWSING_ENABLED=true
WEB_AUTO_SEARCH=false
WEB_SEARCH_PROVIDER=searxng
WEB_SEARCH_URL=https://searxng.nekosunevr.co.uk/
SEARXNG_URL=
WEB_MAX_RESULTS=5
WEB_TIMEOUT_SECONDS=15
WEB_REGION=us-en
WEB_SAFESEARCH=moderate

# Media
MEDIA_REGION=GB
MUSIC_PROVIDER_DEFAULT=soundcloud
SOUNDCLOUD_STREAM_ENDPOINT=https://dl.nekosunevr.co.uk/api/stream

# Interaction
INPUT_MODE=voice
VOICE_ENABLED=false
TTS_PROVIDER=xtts
HISTORY_TURNS=10
REQUEST_TIMEOUT=300

# XTTS
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=en
XTTS_SPEAKER=Ana Florence
XTTS_SPEAKER_WAV=
XTTS_USE_GPU=true
XTTS_STREAM_OUTPUT=true
XTTS_STREAM_CHUNK_SIZE=20
XTTS_STREAM_BUFFER_SECONDS=1.8
XTTS_CHUNK_MAX_CHARS=240
XTTS_MAX_TEXT_CHARS=5000
XTTS_SPEED=1.00

# Speech To Text
STT_PROVIDER=faster-whisper
STT_USE_GPU=true
STT_MODEL=small.en
STT_COMPUTE_TYPE=
STT_BEAM_SIZE=5
STT_BEST_OF=5
STT_VAD_FILTER=false
STT_LANGUAGE=en-US
STT_TIMEOUT_SECONDS=15
STT_PHRASE_TIME_LIMIT_SECONDS=30
STT_PAUSE_THRESHOLD_SECONDS=1.8
STT_NON_SPEAKING_DURATION_SECONDS=1.2
STT_AMBIENT_DURATION_SECONDS=0.6
STT_ENERGY_THRESHOLD=300
STT_DYNAMIC_ENERGY_THRESHOLD=true

# Audio Devices
MIC_DEVICE_INDEX=
SPEAKER_DEVICE_INDEX=
MIC_SAMPLE_RATE=
MIC_CHUNK_SIZE=1024

# Twitch (Neuro-sama style chat reading)
# TWITCH_CHANNEL is the channel to read (no leading #). Leave token blank for
# anonymous read-only. To let NovaAI also post replies into chat, set the bot
# username and an OAuth token (get one at https://twitchtokengenerator.com or
# https://twitchapps.com/tmi — format: oauth:xxxxx).
TWITCH_ENABLED=false
TWITCH_CHANNEL=
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
# How NovaAI decides which chat messages to answer: mention | all | command
#   mention = reply when the bot/companion name is mentioned
#   command = reply only to messages starting with "!ask"
#   all     = reply to everything (heavy; uses the reply cooldown)
TWITCH_REPLY_MODE=mention
TWITCH_REPLY_COOLDOWN=8

# RAG memory (learns/remembers across sessions; not model fine-tuning)
RAG_ENABLED=true
# local = sentence-transformers on CPU (default). ollama = use a local Ollama
# embedding model (e.g. embeddinggemma). openai = use an OpenAI-compatible
# /embeddings endpoint (reuses LLM_API_URL + LLM_API_KEY).
RAG_EMBEDDING_PROVIDER=local
# For local: a sentence-transformers id. For ollama: an Ollama model name
# (run `ollama pull embeddinggemma`). For openai: the API's embedding model id.
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=4
RAG_MIN_SCORE=0.25

# Game playing (Minecraft via Mineflayer). Requires Node.js 18+ and a running
# Minecraft server. Run 'npm install' inside node/minecraft-bridge first.
GAME_ENABLED=false
GAME_DRIVER=minecraft
GAME_TICK_SECONDS=4
MC_HOST=127.0.0.1
MC_PORT=25565
# For MC_AUTH=offline this is just the in-game name. For MC_AUTH=microsoft set it
# to your Microsoft account email (use a SECOND account so NovaAI is separate).
MC_USERNAME=NovaAI
# offline = cracked/LAN server (no auth). microsoft = real online account: on
# first launch the bridge prints a code + microsoft.com/link URL to the chat;
# enter it once and the token is cached in MC_PROFILES_FOLDER.
MC_AUTH=offline
# Where the Microsoft login token is cached (so you don't re-login every time).
# Leave blank to use node/minecraft-bridge/.minecraft-auth.
MC_PROFILES_FOLDER=
# Pin a Minecraft version if auto-detect picks the wrong one (e.g. 1.20.4).
MC_VERSION=
MC_BRIDGE_PORT=8767
# Live view: a browser-based 3D window onto the bot's surroundings so you can
# watch what it's doing without opening the Minecraft client. Open it from the
# Game page ("Live View") or browse to http://127.0.0.1:<port>. Requires
# prismarine-viewer (installed by `npm install` in node/minecraft-bridge).
MC_VIEWER_PORT=8768
# Live inventory viewer port (shows chests/crafting/furnace windows too). The
# "Live View" button opens a combined dashboard (3D world + this inventory).
MC_INVENTORY_PORT=8769
# false = third-person orbit camera (recommended — drag the mouse to look around).
# true = first-person, but prismarine-viewer's first-person can render the player
# model in the way (looks odd), so third-person is the default.
MC_VIEWER_FIRST_PERSON=false
# Live-view textures (prismarine-viewer) only cover up to ~1.21.4. On a newer
# server the bridge auto-renders with the highest supported version so textures
# load. Override here if needed (e.g. 1.21.4).
MC_VIEWER_VERSION=
# Your in-game username so NovaAI knows who its OWNER is — "follow me", "bring me
# diamonds", defend-me, etc. target this player. Defaults to OWNER_NAME.
MC_OWNER_USERNAME=
# Comma-separated player names NovaAI is allowed to HELP when they ask in chat
# (it reads in-game chat). Leave blank to only help the owner.
MC_HELP_WHITELIST=
# Optional home/base coordinate as x,y,z (e.g. 120,64,-30). NovaAI can go_home to
# return here. Leave blank — it can also set its home in-game with set_home.
MC_HOME=
# Optional explicit path to the node executable if it's not on PATH.
NODE_PATH=

# Who NovaAI treats as its owner across features (the trusted person giving
# commands). Voice-biometric matching isn't implemented yet, so for now the
# person using the app's mic/text is treated as the owner.
OWNER_NAME=

# GAME_DRIVER can be: minecraft | universal | osu | factorio | vrchat
#
# Universal vision+input driver (Terraria, Unturned, Celeste, most TOS-safe
# single-player games): set a multimodal model so NovaAI can "see" the screen.
# Reuses your LLM provider/credentials; e.g. an Ollama vision model like
# 'llava' or 'llama3.2-vision'. Needs: pip install pydirectinput mss pillow
VISION_MODEL=
# Label shown to the agent for the universal driver (e.g. Unturned, Terraria).
GAME_UNIVERSAL_NAME=a PC game
#
# Tip: you can edit all of these per-game in the app's Game panel (pick a driver
# -> its settings appear -> Save) without touching this file.
#
# osu! (OFFLINE/SOLO ONLY). Automating osu! on official servers is BANNABLE.
# Leave this false; set true only if you fully accept the ban risk.
OSU_ALLOW_ONLINE=false
#
# Factorio (structured, via RCON). Start the server with --rcon-port and
# --rcon-password, then set these.
FACTORIO_RCON_HOST=127.0.0.1
FACTORIO_RCON_PORT=27015
FACTORIO_RCON_PASSWORD=
#
# VRChat (official OSC API — enable OSC in VRChat's Action Menu).
# Needs: pip install python-osc
VRCHAT_OSC_HOST=127.0.0.1
VRCHAT_OSC_PORT=9000

# Singing (Neuro-sama style). Backends:
#   local = fully local, no cloud/RVC. Fetches timed lyrics (LRCLIB) and performs
#           them in NovaAI's XTTS voice ON the song's timing; optionally mixes
#           over a backing track you give it. (XTTS isn't pitched, so it's
#           on-beat talk-singing, not melodic singing — but it's 100% local.)
#   rvc   = local RVC voice-conversion of a vocal/acapella reference (.pth model).
#   cloud = hosted singing/voice API.
# In the Sing box: type "Artist - Title" to fetch timed lyrics, or paste lyrics
# directly. The optional backing field accepts a file path (.wav/.mp3) OR a
# YouTube URL (downloaded via yt-dlp); leave it blank to auto-find an
# instrumental. Vocals + backing are always merged into one saved song file.
SINGING_ENABLED=true
SINGING_BACKEND=local
# When no backing is given, auto-find an instrumental/karaoke track on YouTube to
# sing over. Attaching your own backing — a file path or a pasted YouTube URL —
# is optional and overrides this. Vocals + backing are merged into ONE file.
#   Needs: pip install yt-dlp imageio-ffmpeg
#   ffmpeg (from imageio-ffmpeg, system PATH, or FFMPEG_PATH=...) is REQUIRED to
#   decode + merge the backing with the voice. Without it, only the voice plays.
# Rendered songs are saved in audio/songs/ and replayed from there next time you
# sing the same thing. (Works with TTS_PROVIDER=xtts or gtts.)
SINGING_FETCH_INSTRUMENTAL=true
RVC_MODEL_PATH=
SINGING_API_URL=
SINGING_API_KEY=
