# Core
AUTO_TUNE_PERFORMANCE=true
AUTO_TUNE_GOAL=balanced
AUTO_UPDATE_CHECK=true
AUTO_UPDATE_INSTALL=true
AUTO_UPDATE_CACHE_SECONDS=21600
HF_HUB_DISABLE_SYMLINKS_WARNING=1
NOVA_GITHUB_REPO=
NOVA_GITHUB_BRANCH=main

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=dolphin3
LLM_API_URL=
LLM_API_KEY=
LLM_KEEP_ALIVE=30m
LLM_NUM_PREDICT=1200
LLM_TEMPERATURE=0.95

# OpenAI Compatible
OPENAI_MODEL=
OPENAI_API_URL=
OPENAI_API_KEY=
OPENAI_TEMPERATURE=

# Ollama
OLLAMA_MODEL=dolphin3
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=1200
OLLAMA_TEMPERATURE=0.95

# Web Search
WEB_BROWSING_ENABLED=true
WEB_AUTO_SEARCH=false
WEB_SEARCH_PROVIDER=searxng
WEB_SEARCH_URL=https://searxng.nekosunevr.co.uk/
SEARXNG_URL=
WEB_MAX_RESULTS=5
WEB_TIMEOUT_SECONDS=15
WEB_REGION=us-en
WEB_SAFESEARCH=moderate

# Interaction
INPUT_MODE=voice
VOICE_ENABLED=false
TTS_PROVIDER=xtts
HISTORY_TURNS=10
REQUEST_TIMEOUT=300

# XTTS
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=en
XTTS_SPEAKER=Ana Florence
XTTS_SPEAKER_WAV=
XTTS_USE_GPU=true
XTTS_STREAM_OUTPUT=true
XTTS_STREAM_CHUNK_SIZE=20
XTTS_STREAM_BUFFER_SECONDS=1.8
XTTS_CHUNK_MAX_CHARS=240
XTTS_MAX_TEXT_CHARS=5000
XTTS_SPEED=1.00

# Speech To Text
STT_PROVIDER=faster-whisper
STT_USE_GPU=true
STT_MODEL=small.en
STT_COMPUTE_TYPE=
STT_BEAM_SIZE=5
STT_BEST_OF=5
STT_VAD_FILTER=false
STT_LANGUAGE=en-US
STT_TIMEOUT_SECONDS=15
STT_PHRASE_TIME_LIMIT_SECONDS=30
STT_PAUSE_THRESHOLD_SECONDS=1.8
STT_NON_SPEAKING_DURATION_SECONDS=1.2
STT_AMBIENT_DURATION_SECONDS=0.6
STT_ENERGY_THRESHOLD=300
STT_DYNAMIC_ENERGY_THRESHOLD=true

# Audio Devices
MIC_DEVICE_INDEX=
SPEAKER_DEVICE_INDEX=
MIC_SAMPLE_RATE=
MIC_CHUNK_SIZE=1024
